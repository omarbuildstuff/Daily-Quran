# Don't cache HTML — always fetch fresh
/*
  Cache-Control: public, max-age=0, must-revalidate

# Favicons: short cache so updates propagate within an hour
/favicon.ico
  Cache-Control: public, max-age=3600
/favicon-16x16.png
  Cache-Control: public, max-age=3600
/favicon-32x32.png
  Cache-Control: public, max-age=3600
/apple-touch-icon.png
  Cache-Control: public, max-age=3600
/android-chrome-192x192.png
  Cache-Control: public, max-age=3600
/android-chrome-512x512.png
  Cache-Control: public, max-age=3600
/quran-hub-logo.png
  Cache-Control: public, max-age=3600
/site.webmanifest
  Cache-Control: public, max-age=3600

# Font files: proper MIME type, CORS, and long cache
/resolide-serif.otf
  Content-Type: font/otf
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=31536000, immutable
/arsenica-regular.ttf
  Content-Type: font/ttf
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=31536000, immutable
/arsenica-bold.ttf
  Content-Type: font/ttf
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=31536000, immutable

# Hashed assets: safe to cache forever (filename changes on content change)
/assets/*
  Cache-Control: public, max-age=31536000, immutable
